@page
@model IndexModel
@{
    ViewData["Title"] = "Kompletní finanční přehled o všech vašich firmách";
}

<!-- Hero -->
<section class="hero" id="hero">
    <div class="container">
        <div class="hero-content">
            <h1 data-i18n="hero-title">Kompletní finanční přehled<br>o všech vašich firmách</h1>
            <p class="hero-subtitle" data-i18n="hero-subtitle">
                GetFira.io spojuje vaše finanční data na jedné platformě s přehlednými dashboardy,
                forecastingem a reporty, které dávají smysl. Soustřeďte se na růst firmy,
                ne na překlikávání mezi excely.
            </p>
            <div class="hero-ctas">
                <a href="#contact" class="btn btn-primary" data-i18n="hero-cta-primary">Získat VIP přístup</a>
                <a href="#features" class="btn btn-secondary" data-i18n="hero-cta-secondary">Zobrazit funkce</a>
            </div>
        </div>
    </div>
</section>

<!-- Value Highlights -->
<section class="social-proof" aria-label="Value highlights">
    <div class="container">
        <div class="proof-grid">
            <div class="proof-item">
                <span class="proof-item-value" data-i18n="proof-1-value">Pro všechny vaše firmy</span>
                <span class="proof-item-label" data-i18n="proof-1-label">Navrženo pro české podnikání</span>
            </div>
            <div class="proof-item">
                <span class="proof-item-value" data-i18n="proof-2-value">Napojení na účetnictví</span>
                <span class="proof-item-label" data-i18n="proof-2-label">Data přímo z vašich systémů</span>
            </div>
            <div class="proof-item">
                <span class="proof-item-value" data-i18n="proof-3-value">Bez složité implementace</span>
                <span class="proof-item-label" data-i18n="proof-3-label">Rychlé nasazení, jasné výsledky</span>
            </div>
        </div>
    </div>
</section>

<!-- Features -->
<section class="section" id="features">
    <div class="container">
        <h2 class="section-title" data-i18n="features-title">Vše, co potřebujete pro řízení financí</h2>
        <p class="section-subtitle" data-i18n="features-subtitle">
            Od denních dashboardů po roční uzávěrky. GetFira.io se postará o těžkou práci,
            aby váš tým mohl dělat sebevědomá rozhodnutí založená na datech.
        </p>

        <!-- Feature 1: Dashboard -->
        <div class="feature-block">
            <div class="feature-text">
                <h3 data-i18n="feature-dashboard-title">Dashboard a KPI</h3>
                <p data-i18n="feature-dashboard-desc">
                    Sledujte tržby, náklady, marže a stav hotovosti na první pohled. GetFira.io
                    zobrazuje vaše KPI na základě dat z účetnictví, takže vždy víte, jak na tom
                    vaše firma je. Žádné ruční exporty, žádná zastaralá čísla.
                </p>
            </div>
            <div class="feature-image">
                <img src="~/screenshots/dashboard-light.png"
                     data-src-light="/screenshots/dashboard-light.png"
                     data-src-dark="/screenshots/dashboard-dark.png"
                     alt="GetFira.io dashboard zobrazující KPI karty pro tržby, náklady a stav hotovosti"
                     loading="lazy"
                     width="1440" height="900" />
            </div>
        </div>

        <!-- Feature 2: Forecasting -->
        <div class="feature-block">
            <div class="feature-text">
                <h3 data-i18n="feature-forecast-title">Forecasting: Skutečnost vs Plán</h3>
                <p data-i18n="feature-forecast-desc">
                    Porovnejte svůj finanční plán se skutečnými výsledky měsíc po měsíci. GetFira.io
                    automaticky zvýrazňuje odchylky, abyste mohli včas zachytit problémy a upravit
                    strategii dříve, než se stanou nákladnými překvapeními.
                </p>
            </div>
            <div class="feature-image">
                <img src="~/screenshots/forecast-light.png"
                     data-src-light="/screenshots/forecast-light.png"
                     data-src-dark="/screenshots/forecast-dark.png"
                     alt="GetFira.io forecasting zobrazení porovnávající skutečnost s rozpočtem a zvýrazněním odchylek"
                     loading="lazy"
                     width="1440" height="900" />
            </div>
        </div>

        <!-- Feature 3: Reports -->
        <div class="feature-block">
            <div class="feature-text">
                <h3 data-i18n="feature-reports-title">Finanční reporty</h3>
                <p data-i18n="feature-reports-desc">
                    Generujte výkazy P&amp;L, rozvahy a cash flow reporty okamžitě. GetFira.io
                    strukturuje vaše data do přehledných, standardizovaných reportů připravených
                    pro vaše vedení, investory nebo účetní.
                </p>
            </div>
            <div class="feature-image">
                <img src="~/screenshots/pnl-light.png"
                     data-src-light="/screenshots/pnl-light.png"
                     data-src-dark="/screenshots/pnl-dark.png"
                     alt="GetFira.io finanční reporty s přehledy P&amp;L a rozvahy"
                     loading="lazy"
                     width="1440" height="900" />
            </div>
        </div>

        <!-- Feature 4: Invoices -->
        <div class="feature-block">
            <div class="feature-text">
                <h3 data-i18n="feature-invoices-title">Přehled faktur a bankovních transakcí</h3>
                <p data-i18n="feature-invoices-desc">
                    Prohlížejte si faktury a bankovní transakce načtené z vašeho účetního systému
                    na jednom místě. GetFira.io zobrazuje již zpracovaná data a umožňuje jejich
                    mapování pro lepší přehlednost.
                </p>
            </div>
            <div class="feature-image">
                <img src="~/screenshots/invoices-light.png"
                     data-src-light="/screenshots/invoices-light.png"
                     data-src-dark="/screenshots/invoices-dark.png"
                     alt="GetFira.io rozhraní pro přehled faktur a bankovních transakcí"
                     loading="lazy"
                     width="1440" height="900" />
            </div>
        </div>

        <!-- Feature 5: Contracts -->
        <div class="feature-block">
            <div class="feature-text">
                <h3 data-i18n="feature-contracts-title">Sledování ziskovosti zakázek</h3>
                <p data-i18n="feature-contracts-desc">
                    Zjistěte přesně, které zakázky jsou ziskové a které vyčerpávají zdroje. GetFira.io
                    sleduje tržby a náklady na úrovni jednotlivých zakázek, abyste mohli s jistotou
                    vyjednávat, přerozdělovat nebo ukončovat spolupráce.
                </p>
            </div>
            <div class="feature-image">
                <img src="~/screenshots/contracts-light.png"
                     data-src-light="/screenshots/contracts-light.png"
                     data-src-dark="/screenshots/contracts-dark.png"
                     alt="GetFira.io zobrazení ziskovosti zakázek s tržbami a maržemi na zakázku"
                     loading="lazy"
                     width="1440" height="900" />
            </div>
        </div>

        <!-- Feature 6: VAT -->
        <div class="feature-block">
            <div class="feature-text">
                <h3 data-i18n="feature-vat-title">DPH compliance</h3>
                <p data-i18n="feature-vat-desc">
                    Mějte přehled o DPH díky vestavěným výpočtům a reportům. GetFira.io
                    pracuje s českými účetními standardy od základu a automaticky třídí transakce
                    podle sazby DPH pro lepší analytický přehled.
                </p>
            </div>
            <div class="feature-image">
                <img src="~/screenshots/vat-light.png"
                     data-src-light="/screenshots/vat-light.png"
                     data-src-dark="/screenshots/vat-dark.png"
                     alt="GetFira.io DPH compliance dashboard s roztříděnými transakcemi a reporty"
                     loading="lazy"
                     width="1440" height="900" />
            </div>
        </div>
    </div>
</section>

<!-- Benefits -->
<section class="section section-alt" id="benefits">
    <div class="container">
        <h2 class="section-title" data-i18n="benefits-title">Proč si vybrat GetFira.io</h2>
        <p class="section-subtitle" data-i18n="benefits-subtitle">
            Méně času na ruční práci, více času na rozhodnutí, která mají smysl.
        </p>

        <div class="benefits-grid">
            <div class="accordion-item" data-open="false">
                <button class="accordion-trigger" type="button" aria-expanded="false" aria-controls="benefit-1">
                    <span data-i18n="benefit-1-title">Méně ruční práce</span>
                    <svg class="accordion-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                        <polyline points="6 9 12 15 18 9" />
                    </svg>
                </button>
                <div class="accordion-panel" id="benefit-1" role="region">
                    <div class="accordion-panel-inner" data-i18n="benefit-1-desc">
                        Automatizujte sběr dat a reportování. GetFira.io načítá data z vašich
                        účetních nástrojů a bankovních zdrojů a vytváří přehledy. Váš tým se může
                        věnovat analýze a strategii místo ručního zpracování.
                    </div>
                </div>
            </div>

            <div class="accordion-item" data-open="false">
                <button class="accordion-trigger" type="button" aria-expanded="false" aria-controls="benefit-2">
                    <span data-i18n="benefit-2-title">Aktuální data, kterým můžete věřit</span>
                    <svg class="accordion-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                        <polyline points="6 9 12 15 18 9" />
                    </svg>
                </button>
                <div class="accordion-panel" id="benefit-2" role="region">
                    <div class="accordion-panel-inner" data-i18n="benefit-2-desc">
                        GetFira.io pravidelně synchronizuje data z vašich zdrojů, takže dashboardy,
                        reporty a forecasty odrážejí aktuální stav vašeho účetnictví.
                    </div>
                </div>
            </div>

            <div class="accordion-item" data-open="false">
                <button class="accordion-trigger" type="button" aria-expanded="false" aria-controls="benefit-3">
                    <span data-i18n="benefit-3-title">Konsolidace více subjektů</span>
                    <svg class="accordion-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                        <polyline points="6 9 12 15 18 9" />
                    </svg>
                </button>
                <div class="accordion-panel" id="benefit-3" role="region">
                    <div class="accordion-panel-inner" data-i18n="benefit-3-desc">
                        Řídíte více firem nebo dceřiných společností? GetFira.io konsoliduje finanční
                        data ze všech vašich subjektů do jednoho zobrazení. Sledujte metriky na úrovni
                        skupiny i jednotlivých subjektů bez žonglování se samostatnými tabulkami nebo systémy.
                    </div>
                </div>
            </div>

            <div class="accordion-item" data-open="false">
                <button class="accordion-trigger" type="button" aria-expanded="false" aria-controls="benefit-4">
                    <span data-i18n="benefit-4-title">Bezproblémové bankovní integrace</span>
                    <svg class="accordion-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                        <polyline points="6 9 12 15 18 9" />
                    </svg>
                </button>
                <div class="accordion-panel" id="benefit-4" role="region">
                    <div class="accordion-panel-inner" data-i18n="benefit-4-desc">
                        Připojte své bankovní účty a nechte GetFira.io, ať načte transakce. Data
                        se automaticky zobrazují vedle vašich účetních záznamů. Žádné chyby z kopírování.
                    </div>
                </div>
            </div>

            <div class="accordion-item" data-open="false">
                <button class="accordion-trigger" type="button" aria-expanded="false" aria-controls="benefit-5">
                    <span data-i18n="benefit-5-title">České účetní standardy od základu</span>
                    <svg class="accordion-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                        <polyline points="6 9 12 15 18 9" />
                    </svg>
                </button>
                <div class="accordion-panel" id="benefit-5" role="region">
                    <div class="accordion-panel-inner" data-i18n="benefit-5-desc">
                        GetFira.io je postavena s českými účetními standardy v jádru. Kategorie DPH,
                        účtová osnova a formáty reportů odpovídají místním požadavkům od začátku.
                        Zůstáváte v souladu s předpisy bez extra konfigurace nebo doplňků třetích stran.
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- How It Works -->
<section class="section" id="how-it-works">
    <div class="container">
        <h2 class="section-title" data-i18n="how-title">Jak to funguje</h2>
        <p class="section-subtitle" data-i18n="how-subtitle">
            Jednoduché nasazení, rychlé výsledky.
        </p>

        <div class="steps-grid">
            <div class="step-card">
                <div class="step-number">1</div>
                <h3 data-i18n="step-1-title">Připojte svá data</h3>
                <p data-i18n="step-1-desc">
                    Propojte své bankovní účty, importujte faktury a připojte své stávající účetní
                    nástroje. GetFira.io vše stáhne na jedno místo automaticky.
                </p>
            </div>

            <div class="step-arrow" aria-hidden="true">&#8594;</div>

            <div class="step-card">
                <div class="step-number">2</div>
                <h3 data-i18n="step-2-title">Automatická analýza</h3>
                <p data-i18n="step-2-desc">
                    GetFira.io třídí transakce, vytváří dashboardy a generuje reporty bez
                    manuálního zásahu. Váš finanční obraz se pravidelně aktualizuje.
                </p>
            </div>

            <div class="step-arrow" aria-hidden="true">&#8594;</div>

            <div class="step-card">
                <div class="step-number">3</div>
                <h3 data-i18n="step-3-title">Dělejte lepší rozhodnutí</h3>
                <p data-i18n="step-3-desc">
                    S jasnými daty na dosah ruky můžete sledovat trendy, zachytit problémy včas
                    a alokovat zdroje tam, kde mají největší dopad.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Contact -->
<section class="section section-alt" id="contact">
    <div class="container">
        <h2 class="section-title">Získejte předběžný VIP přístup</h2>
        <p class="section-subtitle">
            Pro možnost předběžného VIP přístupu do neveřejné verze nás kontaktujte.
        </p>

        <div class="contact-info-wrap">
            <div class="contact-info-item">
                <svg class="contact-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <a href="tel:+420722920191" class="contact-info-link">+420 722 920 191</a>
            </div>
            <div class="contact-info-item">
                <svg class="contact-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <a href="mailto:info@getfira.io" class="contact-info-link">info@getfira.io</a>
            </div>
        </div>
    </div>
</section>
