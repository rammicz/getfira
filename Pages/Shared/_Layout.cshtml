<!DOCTYPE html>
<html lang="cs" data-theme="light" data-lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " - GetFira.io" : "GetFira.io - Kompletní finanční přehled o všech vašich firmách")</title>
    <meta name="description" content="GetFira.io přináší kompletní finanční přehled — dashboardy, forecasting a reporty na základě dat z vašeho účetnictví." data-i18n-attr="content" data-i18n="meta-description" />
    <meta property="og:title" content="GetFira.io - Kompletní finanční přehled o všech vašich firmách" data-i18n-attr="content" data-i18n="og-title" />
    <meta property="og:description" content="Dashboardy, forecasting a finanční reporty na jednom místě." data-i18n-attr="content" data-i18n="og-description" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="cs_CZ" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Header -->
    <header class="site-header">
        <div class="container">
            <a href="/" class="logo" aria-label="GetFira.io home">GetFira.io</a>

            <nav class="nav-desktop" aria-label="Main navigation">
                <a href="#features" class="nav-link" data-i18n="nav-features">Funkce</a>
                <a href="#benefits" class="nav-link" data-i18n="nav-benefits">Výhody</a>
                <a href="#how-it-works" class="nav-link" data-i18n="nav-how-it-works">Jak to funguje</a>
                <a href="#contact" class="nav-link" data-i18n="nav-contact">Kontakt</a>
            </nav>

            <div class="header-actions">
                <button id="lang-toggle" class="lang-toggle" type="button" aria-label="Switch language">
                    <span id="lang-label">EN</span>
                </button>
                <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle dark mode">
                    <span id="theme-icon" aria-hidden="true">&#9790;</span>
                </button>
                <button id="menu-toggle" class="menu-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-drawer">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
                        <line x1="3" y1="6" x2="21" y2="6" />
                        <line x1="3" y1="12" x2="21" y2="12" />
                        <line x1="3" y1="18" x2="21" y2="18" />
                    </svg>
                </button>
            </div>
        </div>
    </header>

    <!-- Mobile Drawer -->
    <div id="mobile-overlay" class="mobile-drawer-overlay" aria-hidden="true"></div>
    <nav id="mobile-drawer" class="mobile-drawer" role="dialog" aria-label="Mobile navigation" aria-modal="true">
        <button id="drawer-close" class="drawer-close" type="button" aria-label="Close menu">&times;</button>
        <div class="mobile-nav">
            <a href="#features" class="mobile-nav-link" data-i18n="nav-features">Funkce</a>
            <a href="#benefits" class="mobile-nav-link" data-i18n="nav-benefits">Výhody</a>
            <a href="#how-it-works" class="mobile-nav-link" data-i18n="nav-how-it-works">Jak to funguje</a>
            <a href="#contact" class="mobile-nav-link" data-i18n="nav-contact">Kontakt</a>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="site-footer">
        <div class="container">
            <div class="footer-inner">
                <div class="footer-brand" data-i18n-html="footer-brand">
                    &copy; 2026 GetFira.io. Vyvinula <a href="https://abago.cz" target="_blank" rel="noopener">abago.cz</a>
                </div>
                <div class="footer-links">
                    <a href="#" class="footer-link" data-i18n="footer-privacy">Zásady ochrany osobních údajů</a>
                    <a href="#" class="footer-link" data-i18n="footer-terms">Obchodní podmínky</a>
                </div>
                <div class="social-icons">
                    <a href="#" class="social-icon" aria-label="LinkedIn">in</a>
                    <a href="#" class="social-icon" aria-label="Twitter">X</a>
                    <a href="#" class="social-icon" aria-label="GitHub">GH</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
